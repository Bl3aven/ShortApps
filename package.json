{
  "name": "shortapps",
  "private": true,
  "version": "3.0.1",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "npm run build && electron .",
    "lint": "eslint .",
    "package:win": "npm run build && electron-packager . ShortApps --platform=win32 --arch=x64 --out=release --overwrite --prune=false --ignore='^/release($|/)' --ignore='^/data($|/)' --ignore='^/node_modules($|/)' --ignore='^/src($|/)' --ignore='^/public($|/)' --ignore='^/cahier-des-charges($|/)' --ignore='^/versioning($|/)'",
    "preview": "vite preview",
    "serve:local": "node server/local-server.js",
    "start": "npm run build && node server/local-server.js"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^39.2.6",
    "electron-packager": "^17.1.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.13"
  }
}
